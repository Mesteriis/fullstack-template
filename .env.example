# Template/dev-only defaults.
# Do not reuse these values as production secrets.
# Generate real credentials and rotate them per environment.
APP__NAME=Fullstack Template API
APP__VERSION=0.1.0
APP__ENVIRONMENT=local
API__HOST=0.0.0.0
API__PORT=8000
API__PREFIX=/api
DB__POSTGRES_DSN=postgresql+asyncpg://fullstack_template:fullstack_template@localhost:5432/fullstack_template
DB__REDIS_URL=redis://localhost:6379/0
BROKER__TASKIQ_QUEUE_NAME=fullstack-template:taskiq
BROKER__TASKIQ_CONSUMER_GROUP_NAME=fullstack-template:backend
SYSTEM__HEALTH_TIMEOUT_SECONDS=5.0
OBSERVABILITY__ENABLED=true
OBSERVABILITY__LOGS_ENABLED=true
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__TRACES_ENABLED=false
OBSERVABILITY__OTLP_ENDPOINT=
OBSERVABILITY__OTLP_HEADERS=
OBSERVABILITY__METRICS_ENABLED=true
OBSERVABILITY__METRICS_PATH=/metrics
OBSERVABILITY__REQUEST_ID_HEADER=X-Request-ID
OBSERVABILITY__CORRELATION_ID_HEADER=X-Correlation-ID
OBSERVABILITY__SENTRY_ENABLED=false
OBSERVABILITY__GLITCHTIP_DSN=
OBSERVABILITY__TRACE_SAMPLE_RATE=0.1
OBSERVABILITY__PROFILE_SAMPLE_RATE=0.0
OBSERVABILITY__INSTRUMENT_SQLALCHEMY=true
OBSERVABILITY__INSTRUMENT_REDIS=true
OBSERVABILITY__INSTRUMENT_HTTPX=false
RUN_DB_MIGRATIONS=true
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173
BACKEND_UPSTREAM=http://host.docker.internal:8000

VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
VITE_OBSERVABILITY_WEB_VITALS_ENABLED=false
VITE_OBSERVABILITY_TRACE_SAMPLE_RATE=0.1
VITE_OBSERVABILITY_UI_TELEMETRY_ENABLED=false
VITE_OBSERVABILITY_ROUTER_TELEMETRY_ENABLED=true
VITE_OBSERVABILITY_REQUEST_CORRELATION_ENABLED=true
VITE_OBSERVABILITY_SOURCEMAPS_ENABLED=false
